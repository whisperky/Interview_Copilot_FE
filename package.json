{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host --port 5173 --strictPort\" \"wait-on tcp:5173 && cross-env ELECTRON_ENABLE_LOGGING=true electron .\"",
    "dev:web": "vite --host --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "build:web": "vite build",
    "lint": "eslint .",
    "smoke": "node ./scripts/integration-smoke.mjs",
    "preview": "vite preview",
    "preview:web": "vite preview",
    "start:electron": "electron ."
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "4.2.0",
    "@types/node": "20.17.19",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "9.0.1",
    "cross-env": "7.0.3",
    "electron": "30.5.1",
    "electron-builder": "24.13.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "5.4.14",
    "wait-on": "8.0.1"
  }
}
